COMPOSE_PROJECT_NAME=kontrak-central-saga
FRONTEND_APP_DOMAIN=app.kontrak-centralsaga.site
BACKEND_APP_DOMAIN=api.kontrak-centralsaga.site
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
LOCAL_TLS_ENABLED=true

POSTGRES_DB=kontrak_central_saga
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

BACKEND_APP_NAME="Kontrak Central Saga API"
BACKEND_APP_ENV=local
BACKEND_APP_DEBUG=true
BACKEND_APP_KEY=
BACKEND_APP_URL=https://api.kontrak-centralsaga.site
BACKEND_LOG_LEVEL=debug
BACKEND_FILESYSTEM_DISK=public
BACKEND_MEDIA_DISK=public
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,app.kontrak-centralsaga.site

FRONTEND_APP_URL=https://app.kontrak-centralsaga.site
NEXT_PUBLIC_API_BASE_URL=https://api.kontrak-centralsaga.site
SERVER_API_BASE_URL=http://backend

# Email reminder (dipakai oleh `php artisan notifications:send-due-date-reminders`)
# Pisahkan email internal dengan koma. Tanpa ini, hanya client yang dapat email.
NOTIFY_ENABLED=true
NOTIFY_INTERNAL_EMAILS=
NOTIFY_PAYMENT_TERM_REMIND_DAYS=7,1
NOTIFY_CONTRACT_ENDING_REMIND_DAYS=30,7,1
