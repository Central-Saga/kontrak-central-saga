{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "laravel-boost": {
      "type": "local",
      "enabled": true,
      "command": [
        "/opt/homebrew/bin/php",
        "backend/artisan",
        "boost:mcp"
      ]
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    }
  }
}
