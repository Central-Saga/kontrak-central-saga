# Dokploy runtime environment
# Use split domains with SSL terminated by Dokploy / Traefik.

# Frontend service env
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=3000
NEXT_PUBLIC_APP_URL=https://kontrak-centralsaga.web.id
NEXT_PUBLIC_API_BASE_URL=https://api.kontrak-centralsaga.web.id
SERVER_API_BASE_URL=https://api.kontrak-centralsaga.web.id

# Backend service env
APP_NAME="Kontrak Central Saga API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.kontrak-centralsaga.web.id
LOG_LEVEL=info
DB_CONNECTION=pgsql
DB_HOST=<dokploy-postgres-host>
DB_PORT=5432
DB_DATABASE=kontrak_central_saga
DB_USERNAME=<dokploy-postgres-user>
DB_PASSWORD=<dokploy-postgres-password>
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
MEDIA_DISK=public
SANCTUM_STATEFUL_DOMAINS=kontrak-centralsaga.web.id,www.kontrak-centralsaga.web.id
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12
BROADCAST_CONNECTION=log
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@kontrak-centralsaga.web.id
MAIL_FROM_NAME="Kontrak Central Saga API"

# Notification recipients & settings (comma-separated emails)
NOTIFY_INTERNAL_EMAILS=
NOTIFY_PAYMENT_TERM_REMIND_DAYS=7,1
NOTIFY_CONTRACT_ENDING_REMIND_DAYS=30,7,1
NOTIFY_ENABLED=true
