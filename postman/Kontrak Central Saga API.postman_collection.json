      "item": [
        {
          "name": "GET Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{health_url}}",
              "host": [
                "{{health_url}}"
              ]
            },
            "description": "Cek apakah backend aktif."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health check returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Health payload has ok status', function () {",
                  "    pm.expect(json.status).to.eql('ok');",
                  "    pm.expect(json.service).to.eql('backend');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
