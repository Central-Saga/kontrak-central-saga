                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Login response contains token', function () {",
                  "    pm.expect(json.data.token).to.be.a('string');",
                  "    pm.expect(json.data.user.email).to.eql(pm.environment.get('admin_email'));",
